---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SpecPunk',
  description = 'SpecPunk runs locally, tracks context, and enforces your specs so AI work stays scoped, bounded, and useful.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/assets/punk-logo.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/assets/punk-logo-render.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/punk-logo-render.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
